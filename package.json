{
  "name": "bun-mongodb-api",
  "version": "0.10.41",
  "description": "API REST robusta com Bun + MongoDB + ElysiaJS",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
    "seed:local": "bun run src/scripts/seed.ts",
    "seed:bva-erp": "bun run src/scripts/seed-bva-erp.ts",
    "seed:bva-prospects": "bun run src/scripts/seed-bva-prospects.ts",
    "seed:users": "bun run src/scripts/seed-users.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@sinclair/typebox": "^0.34.0",
    "cassandra-driver": "^4.8.0",
    "elysia": "^1.4.29",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
