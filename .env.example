# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/bun-api
# Para MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/database?retryWrites=true&w=majority

# Server Configuration
PORT=3000
NODE_ENV=development

# S3 Storage (MinIO) — obrigatório: sem credenciais, upload/leitura de arquivos falha
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT=https://s3.mirandasoft.com.br
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=m-manage
